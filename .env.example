# GitHub App installation token or fine-grained PAT. Required permissions:
# Contents: Read and write, Pull requests: Read and write, Actions: Read
GITHUB_TOKEN=your_github_token_here
# Comma-separated allowlist. The agent ignores every other repository.
ALLOWED_REPOSITORIES=owner/repository
# The command used to call Claude Code. It must already be authenticated on the server.
CLAUDE_COMMAND=claude
# Optional hard limit for one Claude invocation.
CLAUDE_TIMEOUT_SECONDS=900
# Max automatic fix attempts for one recurring pipeline failure before the agent gives up
# and asks a human to take over.
MAX_AUTOFIX_ATTEMPTS=3
# Max number of `claude` subprocesses allowed to run at once (each is a real process).
MAX_CONCURRENT_REPAIRS=3
# How often (seconds) to poll GitHub for new/updated open PRs and pipeline failures.
# No webhook needed — this token alone is enough.
POLL_INTERVAL_SECONDS=60
# Where to persist "already scanned" state across restarts (relative to the working directory).
STATE_FILE=autofix_state.json
